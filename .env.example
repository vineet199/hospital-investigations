VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Database provider boundary. Currently implemented: supabase.
# Add a new adapter under src/lib/database for postgres, mysql, mssql, oracle, etc.
VITE_DATABASE_PROVIDER=supabase

# Server-side only. Required only when running `pnpm seed:supabase`.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key